# ── Discord application credentials ──────────────────────────────────
# Create your app at https://discord.com/developers/applications
# Enable "Activities" for your app there.

# Client ID (public — used by both server and client)
VITE_CLIENT_ID=your_discord_client_id_here

# Client Secret (server-side only — never expose in client code)
DISCORD_CLIENT_SECRET=your_discord_client_secret_here

# ── Server ────────────────────────────────────────────────────────────
PORT=3001
